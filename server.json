  },
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/cleburn/aegis-mcp/main/assets/icon.png",
      "type": "image/png",
      "size": 128
    }
  ],
  "packages": [
    {
      "registryType": "npm",
      "identifier": "aegis-mcp-server",
      "version": "0.1.10",
      "transport": {
        "type": "stdio"
      }
    }
  ]
}
